# ═══════════════════════════════════════════════════════
# DeepCurrents v2.1 环境变量配置
# ═══════════════════════════════════════════════════════

# ── AI 主提供商 (必填) ──
# 推荐使用 OpenAI GPT-4o，也支持 Groq、OpenRouter 等兼容接口
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=your_openai_api_key
AI_MODEL=gpt-4o

# ── AI 回退提供商 (可选，但推荐) ──
# 当主提供商失败时自动回退到此提供商
AI_FALLBACK_URL=https://api.groq.com/openai/v1/chat/completions
AI_FALLBACK_KEY=your_groq_api_key
AI_FALLBACK_MODEL=llama-3.1-70b-versatile

# ── 飞书 Webhook (可选) ──
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your_bot_id

# ── Telegram Bot (可选) ──
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ═══════════════════════════════════════════════════════
# 以下为可选调优参数（均有合理默认值，无需修改即可运行）
# ═══════════════════════════════════════════════════════

# ── 调度时间（Cron 表达式）──
# CRON_COLLECT=0 * * * *        # 数据采集频率（默认每小时）
# CRON_REPORT=0 8 * * *         # 研报生成时间（默认每天 08:00）
# CRON_CLEANUP=0 3 * * *        # 数据清理时间（默认每天 03:00）

# ── RSS 采集 ──
# RSS_TIMEOUT_MS=15000           # 单源抓取超时（毫秒）
# RSS_CONCURRENCY=10             # 并发抓取数

# ── 熔断器 ──
# CB_MAX_FAILURES=3              # 连续失败 N 次后进入冷却
# CB_COOLDOWN_MS=300000          # 冷却时长（毫秒，默认 5 分钟）

# ── AI 上下文 ──
# AI_TIMEOUT_MS=90000            # AI API 超时（毫秒）
# AI_MAX_CONTEXT_TOKENS=8000     # 传给 AI 的最大上下文 token 预算

# ── 标题去重 ──
# DEDUP_SIMILARITY_THRESHOLD=0.55 # 模糊去重相似度阈值（0-1，越低越激进）
# DEDUP_HOURS_BACK=24            # 去重回溯时间窗口（小时）

# ── 研报 ──
# REPORT_MAX_NEWS=500            # 单次研报最大新闻条数
# DATA_RETENTION_DAYS=30         # 数据保留天数

# ── 聚类 ──
# CLUSTER_SIMILARITY_THRESHOLD=0.3 # 聚类 Jaccard 相似度阈值

# ── 趋势检测 ──
# TRENDING_MAX_TRACKED_TERMS=5000  # 趋势引擎最大追踪关键词数
# TRENDING_MAX_SEEN_HEADLINES=50000 # 标题去重缓存上限

# ── 通知推送 ──
# NOTIFY_MAX_RETRIES=3           # 推送失败最大重试次数
# NOTIFY_BASE_DELAY_MS=1000      # 重试基础延迟（指数退避）

# ── 日志 ──
# LOG_LEVEL=info                 # trace/debug/info/warn/error/fatal
# LOG_PRETTY=true                # 本地开发建议 true，生产可设为 false 输出 JSON
# LOG_TO_FILE=false              # 是否写入本地日志文件
# LOG_FILE_PATH=logs/deepcurrents.log # 日志文件路径（相对项目根目录）
# LOG_TO_STDERR=true             # 是否继续输出到终端 stderr

# ── RSSHub 自建实例 ──
# 自建 RSSHub 地址，用于替换默认的 https://rsshub.app
# 推荐自建以规避公共实例的 403 限流
# RSSHUB_BASE_URL=http://localhost:1200

# ── 网络代理 (关键) ──
# 如果你在国内环境运行，需要配置代理以访问 Google News, Reuters, BBC 等原生 RSS
# 以及让本地 RSSHub 容器能够访问 Telegram (t.me) 等受限资源
# HTTPS_PROXY=http://127.0.0.1:7890

# ── RSSHub Twitter/X 支持 ──
# 从浏览器登录 x.com 后，在 Cookie 中找到 auth_token 的值
# 没有此 Token，所有 Twitter/X 类 RSSHub 源将返回 503
# TWITTER_AUTH_TOKEN=your_twitter_auth_token
