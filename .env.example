# ======================================================
# DeepCurrents Environment Variables
# ======================================================

# -- AI 主提供商（必填）-----------------------------------
# 推荐 OpenAI GPT-4o；也支持 Groq、OpenRouter 等兼容接口
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=your_openai_api_key
AI_MODEL=gpt-4o

# -- Event Intelligence Runtime（正式采集/报告必填）--------
# 宿主机直接运行 app 时使用 localhost。
# 如果使用 docker compose 全栈模式，deep-currents 容器会自动覆盖为容器内地址。
EVENT_INTELLIGENCE_ENABLED=true
EVENT_INTELLIGENCE_POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/deepcurrents
EVENT_INTELLIGENCE_QDRANT_URL=http://localhost:6333
EVENT_INTELLIGENCE_QDRANT_API_KEY=
EVENT_INTELLIGENCE_REDIS_URL=redis://localhost:6379/0
EVENT_INTELLIGENCE_EMBEDDING_MODEL=text-embedding-3-small
EVENT_INTELLIGENCE_RERANKER_MODEL=qwen3-rerank
EVENT_INTELLIGENCE_REPORT_PROFILE=macro_daily
EVENT_INTELLIGENCE_STORE_TIMEOUT_MS=5000
EVENT_INTELLIGENCE_STORE_MAX_RETRIES=1

# -- RSSHub（可选，但推荐本地自建）-------------------------
# 若本机通过 docker compose 启动 RSSHub，宿主机运行 app 时可保持如下地址。
RSSHUB_BASE_URL=http://localhost:1200

# -- AI 回退提供商（可选，推荐）-----------------------------
# 主提供商失败时自动回退
AI_FALLBACK_URL=https://api.groq.com/openai/v1/chat/completions
AI_FALLBACK_KEY=your_groq_api_key
AI_FALLBACK_MODEL=llama-3.1-70b-versatile

# -- 通知渠道（可选）---------------------------------------
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your_bot_id
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ======================================================
# 以下为可选调优参数（都有默认值）
# ======================================================

# -- 调度时间（Cron 表达式）-------------------------------
# CRON_COLLECT=0 * * * *           # 数据采集频率（默认每小时）
# CRON_REPORT=0 8 * * *            # 研报生成时间（默认每天 08:00）

# -- RSS 采集 -------------------------------------------
# RSS_TIMEOUT_MS=15000             # 单源抓取超时（毫秒）
# RSS_CONCURRENCY=10               # 并发抓取数

# -- 熔断器 ----------------------------------------------
# CB_MAX_FAILURES=3                # 连续失败 N 次后进入冷却
# CB_COOLDOWN_MS=300000            # 冷却时长（毫秒，默认 5 分钟）

# -- AI 上下文与行情 --------------------------------------
# AI_TIMEOUT_MS=20000              # AI API 超时（毫秒）
# AI_MAX_CONTEXT_TOKENS=128000     # 传给 AI 的最大上下文 token 预算
# AI_USE_REALTIME_MARKET_CONTEXT=true
# AI_MARKET_CONTEXT_SYMBOLS_LIMIT=6 # 从 asset_symbols.json 自动选取的默认 symbol 数量
# AI_SYMBOL_SEARCH_ENABLED=true    # 未命中映射时自动搜索 symbol
# AI_SYMBOL_SEARCH_TIMEOUT_MS=3000 # 自动搜索 symbol 超时（毫秒）
# ASSET_SYMBOLS_FILE=src/config/asset_symbols.json

# -- 标题去重 / 事件归并 ----------------------------------
# DEDUP_SIMILARITY_THRESHOLD=0.55  # 标题去重相似度阈值（0-1）
# DEDUP_HOURS_BACK=24              # 去重回溯时间窗口（小时）

# -- 研报 -------------------------------------------------
# REPORT_AUTO_SAVE_PREDICTIONS=true
# REPORT_MAX_NEWS=500
# DATA_RETENTION_DAYS=30

# -- 趋势检测 --------------------------------------------
# TRENDING_MAX_TRACKED_TERMS=5000
# TRENDING_MAX_SEEN_HEADLINES=50000

# -- 通知重试 --------------------------------------------
# NOTIFY_MAX_RETRIES=3             # 推送失败最大重试次数
# NOTIFY_BASE_DELAY_MS=1000        # 重试基础延迟（指数退避）

# -- 日志 -------------------------------------------------
# LOG_LEVEL=info                   # trace/debug/info/warn/error/fatal
# LOG_PRETTY=true
# LOG_TO_FILE=false
# LOG_FILE_PATH=logs/deepcurrents.log
# LOG_TO_STDERR=true

# -- 网络代理（关键）--------------------------------------
# 宿主机直接运行 app / test_tools 时使用 HTTPS_PROXY。
# Compose 容器（rsshub + deep-currents）使用 DOCKER_HTTPS_PROXY，
# 不要把宿主机的 127.0.0.1 直接传进容器；容器里应改用 host.docker.internal。
# HTTPS_PROXY=http://127.0.0.1:7890
# DOCKER_HTTPS_PROXY=http://host.docker.internal:7890

# -- RSSHub Twitter/X 支持 --------------------------------
# 从浏览器登录 x.com 后，在 Cookie 中找到 auth_token 的值
# 缺少该值时，Twitter/X 类 RSSHub 源通常返回 503
# TWITTER_AUTH_TOKEN=your_twitter_auth_token
